{
  "name": "hardhat",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "resolve:aave": "hardhat run scripts/resolveAave.ts",
    "resolve:aave:sepolia": "hardhat run scripts/resolveAave.ts --network baseSepolia",
    "resolve:aave:base": "hardhat run scripts/resolveAave.ts --network base",
    "deploy:vault": "hardhat run scripts/deploy.ts",
    "deploy:vault:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:vault:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:all": "npm run resolve:aave -- --network baseSepolia && npm run deploy:vault -- --network baseSepolia && hardhat run scripts/printVault.ts --network baseSepolia",
    "print:vault": "hardhat run scripts/printVault.ts",
    "print:vault:sepolia": "hardhat run scripts/printVault.ts --network baseSepolia",
    "print:vault:base": "hardhat run scripts/printVault.ts --network base",
    "deploy:all:sepolia": "npm run resolve:aave:sepolia && npm run deploy:vault:sepolia && npm run print:vault:sepolia",
    "deploy:all:base": "npm run resolve:aave:base && npm run deploy:vault:base && npm run print:vault:base",
    "deploy": "hardhat run scripts/deploy.ts",
    "smoke": "hardhat run scripts/smoke.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.13",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.14",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.1",
    "@nomicfoundation/ignition-core": "^0.15.13",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.2",
    "chai": "^4.5.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.15.0",
    "hardhat": "^2.28.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.16",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aave/core-v3": "^1.19.3",
    "@bgd-labs/aave-address-book": "^4.44.22",
    "@openzeppelin/contracts": "^5.4.0"
  }
}
